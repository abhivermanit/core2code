# Keep the build context small and free of secrets.
node_modules
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Build artifacts (rebuilt inside the image)
dist
build
out
coverage
.nyc_output
*.tsbuildinfo

# VCS & CI
.git
.gitignore
.github

# Secrets & local env (never bake into an image)
.env
.env.*
!.env.example

# Local tooling / editor / OS
.vscode
.idea
.DS_Store
*.log

# Docker/compose files themselves
Dockerfile
docker-compose*.yml
.dockerignore

# Docs (not needed at runtime)
*.md
