{
  "name": "create-core2code",
  "version": "0.6.0",
  "description": "Scaffold a new project using the Core2Code engineering framework.",
  "type": "commonjs",
  "bin": {
    "create-core2code": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "template",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "scaffolding",
    "cli",
    "generator",
    "boilerplate",
    "core2code",
    "engineering",
    "production"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "ora": "^5.4.1",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.9.0",
    "@types/prompts": "^2.4.9",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
